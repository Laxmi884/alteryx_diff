          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField expression="if [CRD_SCORE_T] in (0, 6666, 66666, 666666, 7777, 77777, 777777, 8888, 88888, 888888, 9999, 99999, 999999) then  0&#xA;elseif IsNull([CRD_SCORE_T]) then 0&#xA;elseif [CRD_SCORE_T] &lt;300 then 0&#xA;elseif [CRD_SCORE_T] &gt;1000 then  0&#xA;else [CRD_SCORE_T]&#xA;ENDIF" field="CRD_SCORE_T" size="40.20" type="FixedDecimal" enabled="true" />
