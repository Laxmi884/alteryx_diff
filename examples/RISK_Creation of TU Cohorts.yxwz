                <Field name="OMNI_RURAL_URBAN" size="5" source="Formula: if [REGION]='GTA' and [OMNI_RURAL_URBAN] = 'Rural' then 'Urban'&#xA;else [OMNI_RURAL_URBAN]&#xA;endif" type="V_WString" />
                <Field name="TENURE" size="1" source="Formula: IF IsEmpty(TENURE) THEN Null()&#xA;ELSEIF [TENURE] = '-' THEN Null()&#xA;ELSEIF [TENURE] = 'F' THEN 'F'&#xA;ELSEIF [TENURE] = 'C' THEN 'C'&#xA;ELSEIF TENURE = 'L' THEN 'L'&#xA;ELSE Null()&#xA;ENDIF" type="V_WString" />
