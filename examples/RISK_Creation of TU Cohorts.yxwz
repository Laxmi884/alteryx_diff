                <Field name="POSTAL_CODE" size="16777216" source="File: odbc:DSN=Snowflake SL|||SELECT SAGEN_REFERENCE_NUMBER,&#xA;BOR_ID,&#xA;BOR_FIRST_NAME,&#xA;BOR_LAST_NAME,&#xA;BOR_SIN,&#xA;BOR_DOB,&#xA;STREET_DIRECTION,&#xA;ADDR_SUFFIX,&#xA;UNIT_NUM,&#xA;STREET_NUM,&#xA;STREET_NAME,&#xA;STREET_TYPE,&#xA;CITY,&#xA;PROVINCE,&#xA;POSTAL_CODE,&#xA;CRD_SCORE_T&#xA;FROM &quot;SPANALYTICS&quot;.&quot;ORIGINATION&quot;.&quot;SCORE_LEVEL&quot;" type="V_WString" />
                <Field name="CRD_SCORE_T" scale="20" size="40" source="Formula: if [CRD_SCORE_T] in (0, 6666, 66666, 666666, 7777, 77777, 777777, 8888, 88888, 888888, 9999, 99999, 999999) then  0&#xA;elseif IsNull([CRD_SCORE_T]) then 0&#xA;elseif [CRD_SCORE_T] &lt;300 then 0&#xA;elseif [CRD_SCORE_T] &gt;1000 then  0&#xA;else [CRD_SCORE_T]&#xA;ENDIF" type="FixedDecimal" />
                <Field name="CV_RANGE" size="1073741823" source="Formula: if [CRD_SCORE_T] &gt;= 0 and [CRD_SCORE_T] &lt; 680 then '0TO679'&#xA;elseif [CRD_SCORE_T] &gt;= 680 and [CRD_SCORE_T] &lt; 720 then '680TO719'&#xA;elseif [CRD_SCORE_T] &gt;= 720 and [CRD_SCORE_T] &lt; 760 then '720TO759'&#xA;elseif [CRD_SCORE_T] &gt;= 760 and [CRD_SCORE_T] &lt; 800 then '760TO799'&#xA;elseif [CRD_SCORE_T] &gt;= 800 then 'GE800'&#xA;else Null()&#xA;endif" type="V_WString" />
                <Field name="DATE" source="Formula: if IsEmpty([PRINT_DATE]) then [APPL_RECEIVED_DATE]&#xA;elseif IsNull([PRINT_DATE]) then [APPL_RECEIVED_DATE]&#xA;else [PRINT_DATE]&#xA;endif" type="Date" />
                <Field name="YEAR" source="Formula: DateTimeYear([DATE])" type="Double" />
                <Field name="VINTAGE" size="1073741823" source="Formula: if [YEAR] &lt;= 2020 then 'LE2020'&#xA;elseif [YEAR] = 2021 then '2021'&#xA;elseif [YEAR] = 2022 then '2022'&#xA;elseif [YEAR] = 2023 then '2023'&#xA;elseif [YEAR] = 2024 then '2024'&#xA;elseif [YEAR] = 2025 then '2025'&#xA;else Null()&#xA;endif" type="V_WString" />
                <Field name="REGION" size="1073741823" source="Formula: IF [RRM_PROPERTY_REGION] = 'PACIFIC' THEN 'PAC'&#xA;ELSEIF [RRM_PROPERTY_REGION] = 'ALBERTA' THEN 'ALB'&#xA;ELSEIF [RRM_PROPERTY_REGION] = 'PRAIRIES' THEN 'PRA'&#xA;ELSEIF [RRM_PROPERTY_REGION] = 'ONTARIO' THEN 'ONT'&#xA;ELSEIF [RRM_PROPERTY_REGION] = 'GTA' THEN 'GTA'&#xA;ELSEIF [RRM_PROPERTY_REGION] = 'QUEBEC' THEN 'QUE'&#xA;ELSEIF [RRM_PROPERTY_REGION] = 'ATLANTIC' THEN 'ATL'&#xA;ELSE Null()&#xA;ENDIF&#xA;" type="V_WString" />
                <Field name="AREA" size="1073741823" source="Formula: if [OMNI_RURAL_URBAN] = 'Urban' then 'U'&#xA;elseif [OMNI_RURAL_URBAN] = 'Rural' then 'R'&#xA;else Null()&#xA;endif" type="V_WString" />
              </RecordInfo>
            </MetaInfo>
            <MetaInfo connection="False">
              <RecordInfo>
                <Field name="POLICY_SID" scale="0" size="39" source="File: odbc:DSN=Snowflake_RiskAnalytics;UID=417000030@sagen.ca|||select POLICY_SID&#xA;from SPDW.DM_FIN.DMF_BASE_CAP_ACTUAL&#xA;where time_mth_sid = 202512 and (BVA_SOURCE = 'E' or 		BVA_UNREPORTED_LENDER_FLAG = 'Y')" type="FixedDecimal" />
                <Field name="SAGEN_REFERENCE_NUMBER" size="20" source="File: odbc:DSN=Snowflake SL|||SELECT sagen_reference_number, product_line_of_business, rrm_property_region, omni_rural_urban, tenure, policy_sid, print_date, appl_received_date&#xA;FROM &quot;SPANALYTICS&quot;.&quot;ORIGINATION&quot;.&quot;RISK_LEVEL&quot;&#xA;where snapshot_month = 202512" type="V_WString" />
                <Field name="PRODUCT_LINE_OF_BUSINESS" size="100" source="File: odbc:DSN=Snowflake SL|||SELECT sagen_reference_number, product_line_of_business, rrm_property_region, omni_rural_urban, tenure, policy_sid, print_date, appl_received_date&#xA;FROM &quot;SPANALYTICS&quot;.&quot;ORIGINATION&quot;.&quot;RISK_LEVEL&quot;&#xA;where snapshot_month = 202512" type="V_WString" />
